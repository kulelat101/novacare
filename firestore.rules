rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function myUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(myUserPath());
    }

    function myUser() {
      return get(myUserPath()).data;
    }

    function userRole() {
      return hasUserProfile() ? myUser().role : '';
    }

    function isStaff() {
      return signedIn() && userRole() in [
        'admin', 'staff', 'nurse', 'doctor',
        'Admin', 'Staff', 'Nurse', 'Doctor'
      ];
    }

    function isPatient() {
      return signedIn() && userRole() in ['patient', 'Patient'];
    }

    function matchesLinkedPatientId(value) {
      return isPatient()
        && value != null
        && value != ''
        && (
          value == myUser().linkedPatientId ||
          value == myUser().patientId ||
          value == myUser().linkedPatientDocId ||
          value == myUser().patientDocId ||
          value == myUser().visiblePatientId
        );
    }

    function patientPath(patientDocId) {
      return /databases/$(database)/documents/patients/$(patientDocId);
    }

    function patientData(patientDocId) {
      return get(patientPath(patientDocId)).data;
    }

    function ownsPatientPath(patientDocId) {
      return isPatient() && (
        matchesLinkedPatientId(patientDocId) ||
        (
          exists(patientPath(patientDocId)) && (
            matchesLinkedPatientId(patientData(patientDocId).id) ||
            matchesLinkedPatientId(patientData(patientDocId).docId) ||
            matchesLinkedPatientId(patientData(patientDocId).documentId) ||
            matchesLinkedPatientId(patientData(patientDocId).patientId) ||
            matchesLinkedPatientId(patientData(patientDocId).visiblePatientId) ||
            matchesLinkedPatientId(patientData(patientDocId).chartId) ||
            matchesLinkedPatientId(patientData(patientDocId).caseNo) ||
            patientData(patientDocId).patientUserId == request.auth.uid ||
            patientData(patientDocId).patientUid == request.auth.uid ||
            patientData(patientDocId).authUid == request.auth.uid ||
            patientData(patientDocId).uid == request.auth.uid ||
            (
              request.auth.token.email != null && (
                patientData(patientDocId).email == request.auth.token.email ||
                patientData(patientDocId).emailAddress == request.auth.token.email
              )
            )
          )
        )
      );
    }

    function ownsRecordData(data) {
      return isPatient() && (
        matchesLinkedPatientId(data.patientId) ||
        matchesLinkedPatientId(data.visiblePatientId) ||
        matchesLinkedPatientId(data.patientDocId) ||
        matchesLinkedPatientId(data.linkedPatientId) ||
        matchesLinkedPatientId(data.chartId) ||
        matchesLinkedPatientId(data.caseNo) ||
        data.patientUserId == request.auth.uid ||
        data.patientUid == request.auth.uid ||
        data.authUid == request.auth.uid ||
        data.uid == request.auth.uid ||
        (
          request.auth.token.email != null && (
            data.email == request.auth.token.email ||
            data.emailAddress == request.auth.token.email
          )
        )
      );
    }

    function patientCanReadPortalCollection(collectionId, data) {
      return collectionId in [
        'billingItems',
        'dischargeSummaries',
        'laboratoryResults',
        'imagingResults',
        'imagingReports'
      ] && ownsRecordData(data);
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isStaff());
      allow create, update: if signedIn() && (request.auth.uid == userId || isStaff());
      allow delete: if isStaff();
    }

    match /patients/{patientDocId} {
      allow read: if isStaff() || ownsPatientPath(patientDocId);
      allow create, update, delete: if isStaff();

      // Demo-friendly patient self-update. The UI limits patient edits to
      // Demographics and Emergency Contact. For production, restrict this with
      // request.resource.data.diff(resource.data).affectedKeys().hasOnly([...]).
      allow update: if ownsPatientPath(patientDocId);

      match /{subCollection}/{recordId} {
        allow read: if isStaff() || ownsPatientPath(patientDocId) || patientCanReadPortalCollection(subCollection, resource.data);
        allow create, update, delete: if isStaff();
      }
    }

    // Collection-group support for legacy records saved under mixed patient IDs.
    match /{path=**}/billingItems/{recordId} {
      allow read: if isStaff() || ownsRecordData(resource.data);
      allow create, update, delete: if isStaff();
    }

    match /{path=**}/dischargeSummaries/{recordId} {
      allow read: if isStaff() || ownsRecordData(resource.data);
      allow create, update, delete: if isStaff();
    }

    match /{path=**}/laboratoryResults/{recordId} {
      allow read: if isStaff() || ownsRecordData(resource.data);
      allow create, update, delete: if isStaff();
    }

    match /{path=**}/imagingResults/{recordId} {
      allow read: if isStaff() || ownsRecordData(resource.data);
      allow create, update, delete: if isStaff();
    }

    match /{path=**}/imagingReports/{recordId} {
      allow read: if isStaff() || ownsRecordData(resource.data);
      allow create, update, delete: if isStaff();
    }

    // Staff-only clinical collection-group reads used by SavedRecordsPanel fallbacks.
    match /{path=**}/healthAssessments/{recordId} {
      allow read, create, update, delete: if isStaff();
    }

    match /{path=**}/nursesNotes/{recordId} {
      allow read, create, update, delete: if isStaff();
    }

    match /{path=**}/dailyChecklists/{recordId} {
      allow read, create, update, delete: if isStaff();
    }

    match /{path=**}/vitalSigns/{recordId} {
      allow read, create, update, delete: if isStaff();
    }

    match /{path=**}/intakeOutput/{recordId} {
      allow read, create, update, delete: if isStaff();
    }

    match /{path=**}/ivSheet/{recordId} {
      allow read, create, update, delete: if isStaff();
    }

    match /{path=**}/doctorOrders/{recordId} {
      allow read, create, update, delete: if isStaff();
    }

    match /{path=**}/medicationRecords/{recordId} {
      allow read, create, update, delete: if isStaff();
    }

    match /loginLogs/{logId} {
      allow read: if isStaff();
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isStaff();
    }
  }
}
